# Application
APP_NAME=Math Tutor
APP_VERSION=0.1.0
DEBUG=false

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=math_tutor

# LLM Configuration
LLM_PROVIDER=openai
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO